<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <script src="//unpkg.com/alpinejs" defer></script>

    {% set elementId = craft.app.request.getParam('elementId') %}
    {% set siteId = craft.app.request.getParam('siteId') %}
    {% set entry = craft.app.elements.getElementById(elementId, null, siteId) %}

    {% if entry %}
        {% include '_helpers/seo.twig' with { entry } %}
    {% endif %}

    <style>
        /* Reset & Base */
        *, *::before, *::after { box-sizing: border-box; }
        [x-cloak] { display: none; }

        body {
            margin: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif;
            font-size: 14px;
            line-height: 1.5;
            color: #1e1e1e;
            background: #f5f5f5;
            -webkit-font-smoothing: antialiased;
        }

        img { max-width: 100%; display: block; }

        /* Layout */
        .seo-preview {
            max-width: 680px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .seo-preview__header {
            font-size: 15px;
            font-weight: 600;
            color: #6b7280;
            margin-bottom: 1rem;
            letter-spacing: 0.02em;
        }

        .panel {
            margin-top: 2rem;
        }

        .panel__label {
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.75rem;
        }

        /* Google Card */
        .google-card {
            background: #fff;
            padding: 1.25rem;
            border-radius: 8px;
            border: 1px solid #e5e7eb;
            max-width: 600px;
        }

        .google-card__breadcrumb {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.25rem;
        }

        .google-card__favicon {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #f1f3f4;
            border: 1px solid #ecedef;
            flex-shrink: 0;
            object-fit: contain;
            padding: 4px;
        }

        .google-card__url-group {
            min-width: 0;
        }

        .google-card__site-name {
            display: block;
            font-size: 14px;
            color: #202124;
            line-height: 1.3;
        }

        .google-card__url {
            display: block;
            font-size: 12px;
            color: #4d5156;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .google-card__title {
            font-size: 20px;
            font-weight: 400;
            line-height: 1.3;
            color: #1a0dab;
            margin: 0.25rem 0 0;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
        }

        .google-card__description {
            font-size: 14px;
            line-height: 1.58;
            color: #4d5156;
            margin: 0.25rem 0 0;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
        }

        /* Facebook Card */
        .facebook-card {
            background: #fff;
            border: 1px solid #dadde1;
            border-radius: 2px;
            overflow: hidden;
            max-width: 500px;
        }

        .facebook-card__image {
            aspect-ratio: 1.91 / 1;
            background: #f0f2f5;
            overflow: hidden;
        }

        .facebook-card__image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .facebook-card__body {
            padding: 0.75rem;
            background: #f2f3f5;
        }

        .facebook-card__domain {
            display: block;
            font-size: 12px;
            color: #606770;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }

        .facebook-card__title {
            font-size: 16px;
            font-weight: 600;
            line-height: 1.3;
            color: #1d2129;
            margin: 0.2rem 0 0;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        .facebook-card__description {
            font-size: 14px;
            line-height: 1.4;
            color: #606770;
            margin: 0.15rem 0 0;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
        }

        /* Twitter/X Card */
        .x-card {
            border: 1px solid #cfd9de;
            border-radius: 16px;
            overflow: hidden;
            max-width: 500px;
            background: #fff;
        }

        .x-card__image--large {
            aspect-ratio: 2 / 1;
            background: #f7f9f9;
            overflow: hidden;
        }

        .x-card__image--large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .x-card__body {
            display: flex;
            gap: 0;
        }

        .x-card__image--small {
            width: 130px;
            flex-shrink: 0;
            background: #f7f9f9;
            overflow: hidden;
        }

        .x-card__image--small img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .x-card__text {
            padding: 0.75rem;
            min-width: 0;
        }

        .x-card__domain {
            display: block;
            font-size: 13px;
            color: #536471;
        }

        .x-card__title {
            font-size: 15px;
            font-weight: 700;
            line-height: 1.3;
            color: #0f1419;
            margin: 0.1rem 0 0;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        .x-card__description {
            font-size: 15px;
            line-height: 1.4;
            color: #536471;
            margin: 0.1rem 0 0;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        /* Character Counts */
        .char-counts {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            margin-top: 1rem;
            max-width: 360px;
        }

        .char-count {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .char-count__row {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: #6b7280;
        }

        .char-count__bar {
            height: 2px;
            border-radius: 1px;
            background: #e5e7eb;
        }

        .char-count__bar-fill {
            height: 100%;
            border-radius: 1px;
            transition: width 0.2s;
        }

        .char-count.is-ok .char-count__value { color: #16a34a; }
        .char-count.is-ok .char-count__bar-fill { background: #16a34a; }

        .char-count.is-warning .char-count__value { color: #ca8a04; }
        .char-count.is-warning .char-count__bar-fill { background: #ca8a04; }

        .char-count.is-over .char-count__value { color: #dc2626; font-weight: 600; }
        .char-count.is-over .char-count__bar-fill { background: #dc2626; }

        .char-count.is-empty .char-count__value { color: #9ca3af; }
        .char-count.is-empty .char-count__bar-fill { background: #9ca3af; }
    </style>
</head>
<body>
    <div class="seo-preview" x-data="seoPreview()" x-cloak>
        <div class="seo-preview__header">SEO Preview</div>

        {# Google #}
        <div class="panel">
            <div class="panel__label">Google</div>
            <div class="google-card">
                <div class="google-card__breadcrumb">
                    <img class="google-card__favicon" src="/favicon.ico" alt="" onerror="this.style.display='none'">
                    <div class="google-card__url-group">
                        <span class="google-card__site-name" x-text="ogSiteName || '{{ craft.app.request.hostName }}'"></span>
                        <span class="google-card__url">{{ entry.url ?? '' }}</span>
                    </div>
                </div>
                <h3 class="google-card__title" x-text="googleTitle"></h3>
                <p class="google-card__description" x-text="googleDescription"></p>
            </div>

            <div class="char-counts">
                <div class="char-count" :class="'is-' + charStatus(googleTitle.length, limits.googleTitle)">
                    <div class="char-count__row">
                        <span>Title</span>
                        <span class="char-count__value" x-text="googleTitle.length + ' / ' + limits.googleTitle"></span>
                    </div>
                    <div class="char-count__bar">
                        <div class="char-count__bar-fill" :style="{ width: Math.min(100, (googleTitle.length / limits.googleTitle) * 100) + '%' }"></div>
                    </div>
                </div>
                <div class="char-count" :class="'is-' + charStatus(googleDescription.length, limits.googleDescription)">
                    <div class="char-count__row">
                        <span>Description</span>
                        <span class="char-count__value" x-text="googleDescription.length + ' / ' + limits.googleDescription"></span>
                    </div>
                    <div class="char-count__bar">
                        <div class="char-count__bar-fill" :style="{ width: Math.min(100, (googleDescription.length / limits.googleDescription) * 100) + '%' }"></div>
                    </div>
                </div>
            </div>
        </div>

        {# Facebook #}
        <div class="panel">
            <div class="panel__label">Facebook</div>
            <div class="facebook-card">
                <template x-if="facebookImage">
                    <div class="facebook-card__image">
                        <img :src="facebookImage" alt="">
                    </div>
                </template>
                <div class="facebook-card__body">
                    <span class="facebook-card__domain" x-text="facebookSiteName || '{{ craft.app.request.hostName }}'"></span>
                    <h3 class="facebook-card__title" x-text="facebookTitle"></h3>
                    <p class="facebook-card__description" x-text="facebookDescription"></p>
                </div>
            </div>

            <div class="char-counts">
                <div class="char-count" :class="'is-' + charStatus(facebookTitle.length, limits.facebookTitle)">
                    <div class="char-count__row">
                        <span>Title</span>
                        <span class="char-count__value" x-text="facebookTitle.length + ' / ' + limits.facebookTitle"></span>
                    </div>
                    <div class="char-count__bar">
                        <div class="char-count__bar-fill" :style="{ width: Math.min(100, (facebookTitle.length / limits.facebookTitle) * 100) + '%' }"></div>
                    </div>
                </div>
            </div>
        </div>

        {# Twitter / X #}
        <div class="panel">
            <div class="panel__label">Twitter / X</div>
            <div class="x-card">
                <template x-if="xImage && xCardType === 'summary_large_image'">
                    <div class="x-card__image--large">
                        <img :src="xImage" alt="">
                    </div>
                </template>
                <div class="x-card__body">
                    <template x-if="xImage && xCardType !== 'summary_large_image'">
                        <div class="x-card__image--small">
                            <img :src="xImage" alt="">
                        </div>
                    </template>
                    <div class="x-card__text">
                        <span class="x-card__domain" x-text="'{{ craft.app.request.hostName }}'"></span>
                        <h3 class="x-card__title" x-text="xTitle"></h3>
                        <p class="x-card__description" x-text="xDescription"></p>
                    </div>
                </div>
            </div>

            <div class="char-counts">
                <div class="char-count" :class="'is-' + charStatus(xTitle.length, limits.xTitle)">
                    <div class="char-count__row">
                        <span>Title</span>
                        <span class="char-count__value" x-text="xTitle.length + ' / ' + limits.xTitle"></span>
                    </div>
                    <div class="char-count__bar">
                        <div class="char-count__bar-fill" :style="{ width: Math.min(100, (xTitle.length / limits.xTitle) * 100) + '%' }"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function seoPreview() {
            const meta = (selector) => document.querySelector(selector)?.content ?? '';

            const pageTitle = document.title ?? '';
            const metaDescription = meta('meta[name="description"]');
            const ogTitle = meta('meta[property="og:title"]');
            const ogDescription = meta('meta[property="og:description"]');
            const ogImage = meta('meta[property="og:image"]');
            const ogUrl = meta('meta[property="og:url"]');
            const ogSiteName = meta('meta[property="og:site_name"]');
            const twitterCard = meta('meta[name="twitter:card"]');
            const twitterTitle = meta('meta[name="twitter:title"]');
            const twitterDescription = meta('meta[name="twitter:description"]');
            const twitterImage = meta('meta[name="twitter:image"]');

            return {
                pageTitle,
                metaDescription,
                ogTitle,
                ogDescription,
                ogImage,
                ogUrl,
                ogSiteName,
                twitterCard,
                twitterTitle,
                twitterDescription,
                twitterImage,

                get googleTitle() {
                    return this.pageTitle;
                },
                get googleDescription() {
                    return this.metaDescription;
                },

                get facebookTitle() {
                    return this.ogTitle || this.pageTitle;
                },
                get facebookDescription() {
                    return this.ogDescription || this.metaDescription;
                },
                get facebookImage() {
                    return this.ogImage;
                },
                get facebookSiteName() {
                    return this.ogSiteName;
                },

                get xTitle() {
                    return this.twitterTitle || this.ogTitle || this.pageTitle;
                },
                get xDescription() {
                    return this.twitterDescription || this.ogDescription || this.metaDescription;
                },
                get xImage() {
                    return this.twitterImage || this.ogImage;
                },
                get xCardType() {
                    return this.twitterCard || 'summary';
                },

                limits: {
                    googleTitle: 60,
                    googleDescription: 155,
                    facebookTitle: 60,
                    xTitle: 70,
                },

                charStatus(length, limit) {
                    if (length === 0) return 'empty';
                    if (length > limit) return 'over';
                    if (length > limit * 0.9) return 'warning';
                    return 'ok';
                },
            };
        }
    </script>
</body>
</html>
